{
  "name": "huimeng",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:migrate": "pnpm --filter @huimeng/api db:migrate",
    "db:generate": "pnpm --filter @huimeng/api db:generate",
    "comfyui:dev": "pnpm --filter @huimeng/comfyui dev"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  }
}
