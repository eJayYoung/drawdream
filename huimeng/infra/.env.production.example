# ============================================
# 阿里云镜像仓库配置
# ============================================
# 公网: crpi-rfyj03uo49s0515l.cn-hangzhou.personal.cr.aliyuncs.com
# 专网: crpi-rfyj03uo49s0515l-vpc.cn-hangzhou.personal.cr.aliyuncs.com
REGISTRY=crpi-rfyj03uo49s0515l.cn-hangzhou.personal.cr.aliyuncs.com

# 镜像版本标签
API_TAG=api-latest
WEB_TAG=web-latest

# ============================================
# 域名 / 访问地址
# ============================================
CORS_ORIGIN=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_WS_URL=wss://your-domain.com/ws

# ============================================
# 安全配置 (必须修改)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d

# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-postgres-password
POSTGRES_DB=huimeng
POSTGRES_PORT=5432

# ============================================
# Redis 配置
# ============================================
REDIS_PORT=6379

# ============================================
# MinIO 配置
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-strong-minio-password
MINIO_BUCKET=huimeng
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# 服务端口
# ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
API_PORT=8778
WEB_PORT=8777
