  "71": {
    "inputs": {
      "text": "\n  \"prompt\": \"4K 50fps 杜比视界 电影质感，极高真实度。场景为街角老香烟店，白天，柔和的自然光从门口和窗户透进来，形成自然光影。全片采用严格的硬切转场，拒绝任何叠化或溶解特效。配乐为轻柔钢琴曲，缓慢抒情。每个镜头内只有一个角色出现，角色动作以面部表情和呼吸微动为主，双手保持固定姿态。\",\n  \"scene\": \n    \"scene_name\": \"街角老香烟店_组9\",\n    \"scene_type\": \"内景\",\n    \"time_period\": \"白天\",\n    \"env_attr\": \"老式香烟店、木质柜台、自然光\",\n    \"space_attr\": \"狭窄、温暖、怀旧\",\n    \"light_attr\": \"自然柔光、局部阴影\",\n    \"sound_attr\": \"安静\",\n    \"ambient_sound\": \"远处街道声、挂钟滴答声\",\n    \"shots\": [\n      \n        \"character\": \"老板\",\n        \"character_costume\": \"参考图已定\",\n        \"action_type\": \"小孩的手从柜台拿下来\",\n        \"motion_speed\": \"慢\",\n        \"emotion\": \"温柔、坚定\",\n        \"shot_scale\": \"中景\",\n        \"camera_angle\": \"背面越肩\",\n        \"shot_move\": \"固定\",\n        \"shot_depth\": \"正常景深\",\n        \"shot_pace\": \"慢\",\n        \"shot_duration\": \"3s\",\n        \"content\": \"镜头起势精准锁定图1构图。摄影机置于老板背后，越过老板的肩膀拍摄。老板灰色毛衣的背影占据画面左侧，透过他的肩膀，清晰看到柜台对面的小孩正面，小孩的手从柜台拿下来，把手放在柜台下面，神情有点不好意思\",\n        \"vfx\": \"无\",\n        \"dialogue\": \"无\",\n        \"sound_effect\": \"\",\n        \"foley_sound\": \"\"\n      ,\n      \n        \"character\": \"老板\",\n        \"character_costume\": \"参考图已定\",\n        \"action_type\": \"无\",\n        \"motion_speed\": \"慢\",\n        \"emotion\": \"温柔、慈祥\",\n        \"shot_scale\": \"中景\",\n        \"camera_angle\": \"背面越肩\",\n        \"shot_move\": \"固定\",\n        \"shot_depth\": \"正常景深\",\n        \"shot_pace\": \"慢\",\n        \"shot_duration\": \"8s\",\n        \"content\": \"画面和镜头角度保持不变，老板灰色毛衣的背影占据画面左侧，透过他的肩膀，清晰看到柜台对面的小男孩正面\",\n        \"vfx\": \"无\",\n        \"dialogue\": \"你告诉奶奶，就说楼下卖烟的老头说，祝她生日快乐。\",\n        \"sound_effect\": \"无\",\n        \"foley_sound\": \"手指摩擦布料声、呼吸声\"\n      \n    ]\n  ,\n  \"parameters\": \n    \"resolution\": \"1920X1280\",\n    \"fps\": 24,\n    \"duration\": 11,\n    \"cfg_scale\": 7,\n    \"motion_bucket\": 85,\n    \"enhance_prompt\": true,\n    \"audio_generation\": true\n  \n",
